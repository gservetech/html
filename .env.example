# ============================================
# SOCIAL MEDIA AUTOMATION - ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and fill in your credentials
# All APIs below are FREE to use!

# ──────────────────────────────────────────────
# TWITTER / X  (Free Tier - API v2)
# ──────────────────────────────────────────────
# 1. Go to https://developer.twitter.com/en/portal
# 2. Sign up for a FREE developer account
# 3. Create a new Project & App
# 4. Under "Keys and tokens", generate these:
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ──────────────────────────────────────────────
# FACEBOOK  (Graph API - Free)
# ──────────────────────────────────────────────
# 1. Go to https://developers.facebook.com/
# 2. Create a new App (choose "Business" type) - FREE
# 3. Add "Facebook Login" and "Pages API" products
# 4. Create a Facebook Page (if you don't have one)
# 5. Generate a Page Access Token via Graph Explorer:
#    https://developers.facebook.com/tools/explorer/
#    - Select your App
#    - Select "Get Page Access Token"
#    - Grant pages_manage_posts, pages_read_engagement permissions
# 6. Convert to Long-Lived token (lasts 60 days):
#    GET https://graph.facebook.com/v21.0/oauth/access_token?
#      grant_type=fb_exchange_token&
#      client_id={APP_ID}&
#      client_secret={APP_SECRET}&
#      fb_exchange_token={SHORT_LIVED_TOKEN}
FACEBOOK_PAGE_ID=your_page_id_here
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# Optional: second Facebook Page automation for RoyalKing
FACEBOOK_ROYALKING_PAGE_ID=your_royalking_page_id_here
FACEBOOK_ROYALKING_PAGE_ACCESS_TOKEN=your_royalking_long_lived_page_access_token_here
FACEBOOK_ROYALKING_POST_TIME=09:00
FACEBOOK_ROYALKING_TIMEZONE=Asia/Kolkata

# Optional: third Facebook Page automation for Print
FACEBOOK_PRINT_PAGE_ID=your_print_page_id_here
FACEBOOK_PRINT_PAGE_ACCESS_TOKEN=your_print_long_lived_page_access_token_here
FACEBOOK_PRINT_POST_TIME=09:00
FACEBOOK_PRINT_TIMEZONE=Asia/Kolkata

# ──────────────────────────────────────────────
# FACEBOOK GROUP AUTOMATION (Browser Script)
# ──────────────────────────────────────────────
# Meta no longer provides an official Graph API flow for posting into Facebook groups.
# This standalone script uses a saved browser session instead and does NOT change
# the existing Facebook Page API workflow above.
FACEBOOK_GROUP_URL=https://www.facebook.com/groups/your-group-id/
# Optional: exact Page/profile name to post as inside the group
FACEBOOK_GROUP_POST_AS_NAME=Your Page Name
# Optional: browser profile folder used by the standalone group script
FACEBOOK_GROUP_BROWSER_PROFILE_DIR=.facebook-group-browser-profile
# Optional: set to 1 after login/session is stable
FACEBOOK_GROUP_HEADLESS=0
# Optional: timeout for browser actions
FACEBOOK_GROUP_TIMEOUT_MS=120000
# Optional: separate schedule for the group script
FACEBOOK_GROUP_POST_TIME=09:00
FACEBOOK_GROUP_TIMEZONE=Asia/Kolkata

# ──────────────────────────────────────────────
# INSTAGRAM  (Graph API via Facebook - Free)
# ──────────────────────────────────────────────
# 1. Convert your Instagram account to a Business/Creator account
# 2. Link it to your Facebook Page
# 3. In Graph Explorer, get your Instagram Business Account ID:
#    GET /me/accounts?fields=instagram_business_account
# 4. Use the SAME Facebook Page Access Token from above
# NOTE: Instagram API requires images to be hosted at a PUBLIC URL
#       You can use free image hosting services like:
#       - imgur.com (free API)
#       - imgbb.com (free API)
#       - Or any public URL
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_page_access_token_here

# ──────────────────────────────────────────────
# OPTIONAL: Image Hosting (for Instagram)
# ──────────────────────────────────────────────
# imgbb.com offers free image hosting with API
# Sign up at https://imgbb.com/ and get your free API key
IMGBB_API_KEY=your_imgbb_api_key_here

# ──────────────────────────────────────────────
# SCHEDULER SETTINGS
# ──────────────────────────────────────────────
# Time to post daily (24-hour format, e.g., 09:00 for 9 AM)
POST_TIME=09:00
# Timezone (e.g., Asia/Kolkata, America/New_York, etc.)
TIMEZONE=Asia/Kolkata
